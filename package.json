{
    "name": "hokit",
    "version": "3.0.0-next.0",
    "bin": {
        "hokit": "./dist/cli/index.js"
    },
    "files": [
        "dist"
    ],
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./validator": {
            "types": "./dist/validator/index.d.ts",
            "import": "./dist/validator/index.js"
        }
    },
    "scripts": {
