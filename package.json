{
    "name": "hokit",
    "version": "4.0.2",
    "description": "A declarative snippet compiler based on decorators.",
    "keywords": [
        "cursor",
        "snippet",
        "snippets",
        "vscode"
    ],
    "homepage": "https://github.com/uaibritto/hokit",
    "bugs": {
        "url": "https://github.com/uaibritto/hokit/issues"
    },
    "license": "MIT",
    "author": "uaibritto",
    "repository": {
        "type": "git",
        "url": "https://github.com/uaibritto/hokit.git"
    },
    "bin": {
        "hokit": "./dist/cli/index.js"
    },
    "files": [
        "dist"
    ],
    "type": "module",
    "sideEffects": false,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./validator": {
            "types": "./dist/validator/index.d.ts",
            "import": "./dist/validator/index.js"
        }
    },
    "scripts": {
        "build": "tsdown",
        "check": "tsc --noEmit",
        "format": "oxfmt",
        "prepack": "tsdown",
        "test": "pnpm build && node --test"
    },
    "dependencies": {
        "chokidar": "^5.0.0",
        "picocolors": "^1.1.1",
        "reflect-metadata": "^0.2.2",
        "tinyglobby": "^0.2.17",
        "tsx": "^4.22.4",
        "typescript": "^5.9.3"
    },
    "devDependencies": {
        "@types/node": "^26.0.0",
        "oxfmt": "^0.55.0",
        "tsdown": "^0.22.3"
    },
    "engines": {
        "node": ">=20.6.0"
    }
}
