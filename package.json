        "test": "pnpm build && node --test"
    },
    "dependencies": {
        "chokidar": "^5.0.0",
        "picocolors": "^1.1.1",
        "reflect-metadata": "^0.2.2",
        "tinyglobby": "^0.2.17",
        "tsx": "^4.22.4",
        "typescript": "^5.9.3"
    },
    "devDependencies": {
        "@types/node": "^26.0.0",
        "oxfmt": "^0.55.0",
        "tsdown": "^0.22.3"
    },
    "engines": {
        "node": ">=20.6.0"
    }
}
