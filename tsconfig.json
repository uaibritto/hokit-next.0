{
    "compilerOptions": {
        "target": "ESNext",
        "module": "Preserve",
        "strict": true,
        "skipLibCheck": true,
        "noUncheckedIndexedAccess": true,
        "exactOptionalPropertyTypes": true,
        "experimentalDecorators": true,
        "types": ["node", "reflect-metadata"],
        "paths": {
            "@hokit/*": ["./src/*"]
        }
    },

    "include": ["src"]
}
